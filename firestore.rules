rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Match any document in the 'users' collection
    match /users/{userId} {
      // Allow a user to read and write only their own data
      // request.auth != null checks if the user is authenticated
      // request.auth.uid == userId checks if the logged-in user's ID matches the document path
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Also apply this to all subcollections (custom_foods, logbook, etc.)
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
